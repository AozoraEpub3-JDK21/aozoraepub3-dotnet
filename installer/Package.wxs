<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="AozoraEpub3"
           Version="$(Version)"
           Manufacturer="AozoraJDK21"
           Language="1041"
           Codepage="932"
           UpgradeCode="efbb0aeb-ffde-4f48-9110-03575a1d87a7"
           Scope="perMachine">

    <SummaryInformation Keywords="Installer" Description="AozoraEpub3 Installer" />

    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />

    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="AozoraEpub3" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppMenuFolder" Name="AozoraEpub3" />
    </StandardDirectory>

    <ComponentGroup Id="Shortcuts">
      <Component Id="StartMenuShortcut" Directory="AppMenuFolder" Guid="*">
        <Shortcut Id="AppShortcut"
                  Name="AozoraEpub3"
                  Description="Convert Aozora Bunko / Web novels to EPUB3"
                  Target="[INSTALLFOLDER]AozoraEpub3.Gui.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <Shortcut Id="UninstallShortcut"
                  Name="Uninstall AozoraEpub3"
                  Target="[System64Folder]msiexec.exe"
                  Arguments="/x [ProductCode]" />
        <RemoveFolder Id="CleanupAppMenuFolder" Directory="AppMenuFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\AozoraJDK21\AozoraEpub3"
                       Name="installed"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <Feature Id="Main" Title="AozoraEpub3" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="Shortcuts" />
    </Feature>

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

  </Package>
</Wix>
