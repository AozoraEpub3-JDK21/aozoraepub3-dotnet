<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AozoraEpub3.Gui.ViewModels"
             x:Class="AozoraEpub3.Gui.Views.SettingsPageView"
             x:DataType="vm:SettingsPageViewModel">

  <StackPanel Margin="32,24" MaxWidth="480" Spacing="20">

    <!-- タイトル -->
    <TextBlock Text="{DynamicResource Str_SettingsPage_Title}"
               FontSize="20" FontWeight="SemiBold" />

    <!-- 言語 -->
    <StackPanel Spacing="8">
      <TextBlock Text="{DynamicResource Str_SettingsPage_Language}"
                 FontWeight="SemiBold" FontSize="14" />
      <StackPanel Orientation="Horizontal" Spacing="8">
        <RadioButton Content="日本語"
                     IsChecked="{Binding IsLangJapanese}" />
        <RadioButton Content="English"
                     IsChecked="{Binding IsLangEnglish}" />
      </StackPanel>
    </StackPanel>

    <!-- テーマ -->
    <StackPanel Spacing="8">
      <TextBlock Text="{DynamicResource Str_SettingsPage_Theme}"
                 FontWeight="SemiBold" FontSize="14" />
      <ComboBox SelectedIndex="{Binding ThemeIndex}" MinWidth="200">
        <ComboBoxItem Content="{DynamicResource Str_SettingsPage_Theme_Default}" />
        <ComboBoxItem Content="{DynamicResource Str_SettingsPage_Theme_Light}" />
        <ComboBoxItem Content="{DynamicResource Str_SettingsPage_Theme_Dark}" />
      </ComboBox>
    </StackPanel>

    <!-- エディタテーマ -->
    <StackPanel Spacing="8">
      <TextBlock Text="エディタテーマ"
                 FontWeight="SemiBold" FontSize="14" />
      <ComboBox ItemsSource="{Binding EditorThemeNames}"
                SelectedIndex="{Binding EditorThemeIndex}"
                MinWidth="200" />
    </StackPanel>

    <!-- エディタフォント -->
    <StackPanel Spacing="8">
      <TextBlock Text="エディタフォント"
                 FontWeight="SemiBold" FontSize="14" />
      <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
        <TextBox Grid.Row="0" Grid.Column="0"
                 Text="{Binding EditorFontFamily}"
                 Watermark="フォント名（空=テーマデフォルト）"
                 MinWidth="200" />
        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="8,0,0,0">
          <TextBlock Text="サイズ:" VerticalAlignment="Center" />
          <NumericUpDown Value="{Binding EditorFontSize}"
                        Minimum="10" Maximum="24" Increment="1"
                        Width="90" FormatString="0" />
        </StackPanel>
      </Grid>
    </StackPanel>

    <!-- プレビューフォント -->
    <StackPanel Spacing="8">
      <TextBlock Text="プレビューフォント"
                 FontWeight="SemiBold" FontSize="14" />
      <Grid ColumnDefinitions="*,Auto">
        <TextBox Grid.Column="0"
                 Text="{Binding PreviewFontFamily}"
                 Watermark="フォント名（空=テーマデフォルト）"
                 MinWidth="200" />
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="8,0,0,0">
          <TextBlock Text="サイズ:" VerticalAlignment="Center" />
          <NumericUpDown Value="{Binding PreviewFontSize}"
                        Minimum="12" Maximum="32" Increment="1"
                        Width="90" FormatString="0" />
        </StackPanel>
      </Grid>
    </StackPanel>

  </StackPanel>
</UserControl>
