<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AozoraEpub3.Gui.ViewModels"
             xmlns:editor="using:AozoraEpub3.Core.Editor"
             xmlns:views="using:AozoraEpub3.Gui.Views"
             x:Class="AozoraEpub3.Gui.Views.CardBoardView"
             x:DataType="vm:CardBoardViewModel">

  <Grid RowDefinitions="Auto,*,Auto,Auto">

    <!-- ══════ Row 0: ToolBar ══════ -->
    <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
      <StackPanel Orientation="Horizontal" Spacing="4" Margin="8,4">
        <ComboBox ItemsSource="{Binding ModeNames}"
                  SelectedIndex="{Binding SelectedModeIndex}"
                  Width="75" FontSize="12" VerticalAlignment="Center"/>
        <Separator/>
        <Button Content="ルビ" Command="{Binding InsertSnippetCommand}" CommandParameter="ruby"
                ToolTip.Tip="Ctrl+R" Padding="4,2" FontSize="12"/>
        <Button Content="傍点" Command="{Binding InsertSnippetCommand}" CommandParameter="emphasis"
                ToolTip.Tip="Ctrl+E" Padding="4,2" FontSize="12"/>
        <Button Content="太字" Command="{Binding InsertSnippetCommand}" CommandParameter="bold"
                ToolTip.Tip="Ctrl+B" Padding="4,2" FontSize="12"/>
        <Button Content="見出し" Command="{Binding InsertSnippetCommand}" CommandParameter="heading"
                ToolTip.Tip="Ctrl+H" Padding="4,2" FontSize="12"/>
        <Button Content="改頁" Command="{Binding InsertSnippetCommand}" CommandParameter="pagebreak"
                Padding="4,2" FontSize="12"/>
        <Separator/>
        <ToggleButton Content="縦書" IsChecked="{Binding IsVertical}" Padding="4,2" FontSize="12"/>
        <Button Content="整形" Command="{Binding FormatTextCommand}"
                ToolTip.Tip="Ctrl+Shift+F" Padding="4,2" FontSize="12"/>
        <Separator/>
        <ToggleButton Content="Preview" IsChecked="{Binding IsPreviewVisible}"
                      ToolTip.Tip="F5" Padding="4,2" FontSize="12"/>
        <Separator/>
        <Button Content="EPUB変換" Command="{Binding ConvertToEpubCommand}"
                Padding="4,2" FontSize="12" FontWeight="SemiBold"/>
        <Separator/>
        <Button Content="本にする →" Command="{Binding AcceptMigrationCommand}"
                Padding="4,2" FontSize="12" Foreground="#569CD6"
                Background="Transparent" BorderThickness="0"
                ToolTip.Tip="カードを章立てプロジェクトに変換"/>
        <Separator/>
        <ToggleButton Content="？" IsChecked="{Binding CheatSheet.IsVisible}"
                      ToolTip.Tip="F1" Padding="4,2" FontSize="12"/>
      </StackPanel>
    </ScrollViewer>

    <!-- ══════ Row 1: カードリスト + エディタ + プレビュー + チートシート ══════ -->
    <Grid Grid.Row="1" ColumnDefinitions="*,Auto">
      <!-- チートシートパネル（右端） -->
      <views:CheatSheetPanel Grid.Column="1"
                             DataContext="{Binding CheatSheet}"
                             IsVisible="{Binding IsVisible}"/>
    <Grid Grid.Column="0" ColumnDefinitions="250,Auto,*">

      <!-- ── Col 0: カードリスト ── -->
      <Border Grid.Column="0" Background="#252526" Padding="4">
        <Grid RowDefinitions="*,Auto">

          <ListBox x:Name="CardListBox" Grid.Row="0"
                   ItemsSource="{Binding Cards}"
                   SelectedItem="{Binding SelectedCard}"
                   Background="Transparent"
                   BorderThickness="0"
                   DragDrop.AllowDrop="True">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="{x:Type editor:StoryCard}">
                <Border Padding="8" Margin="2" CornerRadius="4"
                        Background="#2D2D30" BorderBrush="#3E3E42" BorderThickness="1">
                  <Border.ContextMenu>
                    <ContextMenu>
                      <MenuItem Header="上に移動"
                                Command="{Binding $parent[ListBox].DataContext.MoveCardUpCommand}"/>
                      <MenuItem Header="下に移動"
                                Command="{Binding $parent[ListBox].DataContext.MoveCardDownCommand}"/>
                      <Separator/>
                      <MenuItem Header="複製"
                                Command="{Binding $parent[ListBox].DataContext.DuplicateCardCommand}"/>
                      <Separator/>
                      <MenuItem Header="ステータス変更">
                        <MenuItem Header="下書き"
                                  Command="{Binding $parent[ListBox].DataContext.ChangeStatusCommand}"
                                  CommandParameter="Draft"/>
                        <MenuItem Header="執筆中"
                                  Command="{Binding $parent[ListBox].DataContext.ChangeStatusCommand}"
                                  CommandParameter="Writing"/>
                        <MenuItem Header="完成"
                                  Command="{Binding $parent[ListBox].DataContext.ChangeStatusCommand}"
                                  CommandParameter="Done"/>
                      </MenuItem>
                      <Separator/>
                      <MenuItem Header="削除"
                                Command="{Binding $parent[ListBox].DataContext.DeleteCardCommand}"/>
                    </ContextMenu>
                  </Border.ContextMenu>
                  <StackPanel Spacing="4">
                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                               FontSize="13" Foreground="#DCDCDC"/>
                    <TextBlock Text="{Binding Body, Converter={x:Static vm:CardPreviewConverter.Instance}}"
                               FontSize="11" Foreground="#858585"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="2"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock FontSize="11" Foreground="#6A9955">
                        <Run Text="{Binding WordCount, StringFormat='{}{0:N0}字'}"/>
                      </TextBlock>
                      <TextBlock FontSize="11" Foreground="#858585"
                                 Text="{Binding Status}"/>
                    </StackPanel>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <!-- 追加ボタン -->
          <Button Grid.Row="1"
                  Content="+ 新しい話を追加"
                  Command="{Binding AddCardCommand}"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Margin="4" Padding="8"
                  FontSize="13"/>
        </Grid>
      </Border>

      <!-- ── Col 1: スプリッター ── -->
      <GridSplitter Grid.Column="1" Width="4"
                    Background="Gray" Opacity="0.3"/>

      <!-- ── Col 2: エディタ + プレビュー ── -->
      <Grid Grid.Column="2" ColumnDefinitions="*,Auto,*">

        <!-- Editor with Line Numbers -->
        <Border Grid.Column="0" Background="#1E1E1E">
          <Grid ColumnDefinitions="Auto,*">
            <!-- Line Number Panel -->
            <Border Grid.Column="0" Background="#252526" Padding="8,4,8,4"
                    BorderBrush="#3E3E42" BorderThickness="0,0,1,0">
              <TextBlock x:Name="LineNumberBlock"
                         FontFamily="BIZ UDGothic, MS Gothic, Consolas, monospace"
                         FontSize="14"
                         Foreground="#858585"
                         TextAlignment="Right"
                         MinWidth="30"
                         Text="1"/>
            </Border>

            <!-- Main TextBox -->
            <TextBox x:Name="EditorTextBox" Grid.Column="1"
                     Text="{Binding ActiveCardBody, Mode=TwoWay}"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     TextWrapping="NoWrap"
                     FontFamily="BIZ UDGothic, MS Gothic, Consolas, monospace"
                     FontSize="14"
                     Background="#1E1E1E"
                     Foreground="#DCDCDC"
                     CaretBrush="#AEAFAD"
                     SelectionBrush="#264F78"
                     BorderThickness="0"
                     Padding="4"/>
          </Grid>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="4"
                      Background="Gray" Opacity="0.3"
                      IsVisible="{Binding IsPreviewVisible}"/>

        <!-- Preview (WebView2Host wired in code-behind) -->
        <Border Grid.Column="2"
                IsVisible="{Binding IsPreviewVisible}"
                BorderBrush="Gray" BorderThickness="1,0,0,0">
          <Grid x:Name="PreviewContainer"/>
        </Border>

      </Grid>
    </Grid>
    </Grid>

    <!-- ══════ Row 2: マイグレーション提案バー + StatusBar ══════ -->

    <!-- マイグレーション提案バー -->
    <Border Grid.Row="2"
            IsVisible="{Binding IsMigrationProposalVisible}"
            Background="#1B3A4B" BorderBrush="#2980B9" BorderThickness="0,1,0,0"
            Padding="12,8">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
        <TextBlock Grid.Column="0" Text="💡" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
        <TextBlock Grid.Column="1" Text="{Binding MigrationProposalText}"
                   Foreground="#E0E0E0" FontSize="13" VerticalAlignment="Center"
                   TextWrapping="Wrap"/>
        <Button Grid.Column="2" Content="本にする →"
                Command="{Binding AcceptMigrationCommand}"
                Foreground="White" Background="#2980B9"
                Padding="12,4" Margin="8,0" FontSize="12" FontWeight="SemiBold"/>
        <Button Grid.Column="3" Content="今後表示しない"
                Command="{Binding SuppressMigrationProposals_CommandCommand}"
                Foreground="#999" Background="Transparent" BorderThickness="0"
                Padding="8,4" FontSize="11"/>
        <Button Grid.Column="4" Content="✕"
                Command="{Binding DismissMigrationProposalCommand}"
                Foreground="#999" Background="Transparent" BorderThickness="0"
                Padding="4,2" FontSize="12"/>
      </Grid>
    </Border>

    <!-- StatusBar -->
    <Border Grid.Row="3" Background="#2D2D30" Padding="8,4">
      <StackPanel Orientation="Horizontal" Spacing="16">
        <TextBlock Text="{Binding StatsText}" Foreground="#DCDCDC"/>
        <!-- マイルストーン通知 -->
        <TextBlock Text="{Binding MilestoneMessage}"
                   IsVisible="{Binding MilestoneMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   Foreground="#6A9955" FontWeight="SemiBold"/>
      </StackPanel>
    </Border>

  </Grid>

</UserControl>
