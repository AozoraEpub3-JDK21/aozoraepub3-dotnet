<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AozoraEpub3.Gui.ViewModels"
             xmlns:editor="using:AozoraEpub3.Core.Editor"
             xmlns:views="using:AozoraEpub3.Gui.Views"
             x:Class="AozoraEpub3.Gui.Views.CardBoardView"
             x:DataType="vm:CardBoardViewModel">

  <Grid>

    <!-- ══════════════════════════════════════════════════════════
         GALLERY MODE（デフォルト）
    ══════════════════════════════════════════════════════════ -->
    <Grid IsVisible="{Binding IsGalleryMode}" RowDefinitions="Auto,*,Auto">

      <!-- ── ギャラリーヘッダー ── -->
      <Border Grid.Row="0"
              Background="#252526"
              BorderBrush="#3E3E42" BorderThickness="0,0,0,1"
              Padding="16,10">
        <Grid ColumnDefinitions="*,Auto,Auto">
          <TextBlock Grid.Column="0"
                     Text="書く"
                     FontSize="18" FontWeight="SemiBold"
                     Foreground="#E0E0E0"
                     VerticalAlignment="Center"/>
          <ComboBox Grid.Column="1"
                    ItemsSource="{Binding ModeNames}"
                    SelectedIndex="{Binding SelectedModeIndex}"
                    Width="75" FontSize="12"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0"/>
          <Button Grid.Column="2"
                  Content="＋ 新しい話"
                  Command="{Binding AddCardCommand}"
                  Padding="12,6" FontSize="13"/>
        </Grid>
      </Border>

      <!-- ── カードグリッド ── -->
      <ScrollViewer Grid.Row="1"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    Background="#1E1E1E">
        <ItemsControl ItemsSource="{Binding Cards}" Margin="16,16,8,8">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type editor:StoryCard}">
              <Button Classes="story-card"
                      Command="{Binding $parent[ItemsControl].DataContext.OpenCardCommand}"
                      CommandParameter="{Binding}">
                <Grid RowDefinitions="Auto,*,Auto">

                  <!-- タイトル -->
                  <TextBlock Grid.Row="0"
                             Text="{Binding Title}"
                             FontSize="14" FontWeight="SemiBold"
                             Foreground="#E0E0E0"
                             TextTrimming="CharacterEllipsis"/>

                  <!-- 本文プレビュー -->
                  <TextBlock Grid.Row="1"
                             Text="{Binding Body, Converter={x:Static vm:CardPreviewConverter.Instance}}"
                             FontSize="12" Foreground="#858585"
                             Margin="0,10,0,0"
                             TextWrapping="Wrap" MaxLines="4"
                             TextTrimming="CharacterEllipsis"/>

                  <!-- フッター：文字数 + ステータス -->
                  <StackPanel Grid.Row="2"
                              Orientation="Horizontal" Spacing="8"
                              Margin="0,10,0,0" VerticalAlignment="Bottom">
                    <TextBlock FontSize="11" Foreground="#6A9955"
                               Text="{Binding WordCount, StringFormat='{}{0:N0}字'}"/>
                    <Border CornerRadius="3" Padding="5,1" Background="#2A2A2E">
                      <TextBlock Text="{Binding Status}" FontSize="10" Foreground="#858585"/>
                    </Border>
                  </StackPanel>

                </Grid>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- ── ギャラリーフッター ── -->
      <Border Grid.Row="2"
              Background="#252526"
              BorderBrush="#3E3E42" BorderThickness="0,1,0,0"
              Padding="16,10">
        <Grid ColumnDefinitions="*,Auto,Auto">
          <TextBlock Grid.Column="0"
                     Text="{Binding StatsText}"
                     Foreground="#858585" FontSize="13"
                     VerticalAlignment="Center"/>
          <Button Grid.Column="1"
                  Content="EPUB 変換"
                  Command="{Binding ConvertToEpubCommand}"
                  Padding="10,6" FontSize="12"
                  Margin="0,0,8,0"/>
          <Button Grid.Column="2"
                  Content="📘 本にする →"
                  Command="{Binding AcceptMigrationCommand}"
                  Padding="10,6" FontSize="12" FontWeight="SemiBold"
                  Foreground="White" Background="#2980B9"/>
        </Grid>
      </Border>

    </Grid>

    <!-- ══════════════════════════════════════════════════════════
         EDITOR MODE（カードをクリックで開く）
    ══════════════════════════════════════════════════════════ -->
    <Grid IsVisible="{Binding IsEditorMode}" RowDefinitions="Auto,*,Auto,Auto">

      <!-- ── ミニツールバー：戻る + タイトル + アクション ── -->
      <Border Grid.Row="0"
              Background="#252526"
              BorderBrush="#3E3E42" BorderThickness="0,0,0,1"
              Padding="4,4">
        <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">

          <!-- 戻るボタン -->
          <Button Grid.Column="0"
                  Content="← 一覧"
                  Command="{Binding BackToGalleryCommand}"
                  Padding="8,4" FontSize="12"
                  Background="Transparent" BorderThickness="0"
                  Foreground="#858585"/>

          <!-- 縦区切り -->
          <Border Grid.Column="1"
                  Width="1" Background="#3E3E42"
                  Margin="6,4" VerticalAlignment="Stretch"/>

          <!-- カードタイトル（編集可能） -->
          <TextBox Grid.Column="2"
                   Text="{Binding ActiveCardTitle, Mode=TwoWay}"
                   FontSize="14" FontWeight="SemiBold"
                   Foreground="#E0E0E0" Background="Transparent"
                   CaretBrush="#AEAFAD"
                   BorderThickness="0" Padding="4,2"
                   Watermark="タイトル..."
                   VerticalAlignment="Center"/>

          <!-- 記法・書式ボタン -->
          <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="2" Margin="4,0">
            <Border Width="1" Background="#3E3E42" Margin="2,4" VerticalAlignment="Stretch"/>
            <Button Content="ルビ"   Command="{Binding InsertSnippetCommand}" CommandParameter="ruby"
                    ToolTip.Tip="Ctrl+R" Padding="4,2" FontSize="12"/>
            <Button Content="傍点"   Command="{Binding InsertSnippetCommand}" CommandParameter="emphasis"
                    ToolTip.Tip="Ctrl+E" Padding="4,2" FontSize="12"/>
            <Button Content="太字"   Command="{Binding InsertSnippetCommand}" CommandParameter="bold"
                    ToolTip.Tip="Ctrl+B" Padding="4,2" FontSize="12"/>
            <Button Content="見出し" Command="{Binding InsertSnippetCommand}" CommandParameter="heading"
                    ToolTip.Tip="Ctrl+H" Padding="4,2" FontSize="12"/>
            <Button Content="改頁"   Command="{Binding InsertSnippetCommand}" CommandParameter="pagebreak"
                    Padding="4,2" FontSize="12"/>
            <Border Width="1" Background="#3E3E42" Margin="2,4" VerticalAlignment="Stretch"/>
            <ToggleButton Content="縦書" IsChecked="{Binding IsVertical}" Padding="4,2" FontSize="12"/>
            <Button Content="自動修正" Command="{Binding FormatTextCommand}"
                    ToolTip.Tip="Ctrl+Shift+F" Padding="4,2" FontSize="12"/>
          </StackPanel>

          <!-- アクションボタン -->
          <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="2" Margin="4,0">
            <Border Width="1" Background="#3E3E42" Margin="2,4" VerticalAlignment="Stretch"/>
            <ToggleButton Content="縦書確認" IsChecked="{Binding IsPreviewVisible}"
                          ToolTip.Tip="F5" Padding="4,2" FontSize="12"/>
            <Border Width="1" Background="#3E3E42" Margin="2,4" VerticalAlignment="Stretch"/>
            <Button Content="EPUB変換" Command="{Binding ConvertToEpubCommand}"
                    Padding="4,2" FontSize="12" FontWeight="SemiBold"/>
            <Border Width="1" Background="#3E3E42" Margin="2,4" VerticalAlignment="Stretch"/>
            <ToggleButton Content="？" IsChecked="{Binding CheatSheet.IsVisible}"
                          ToolTip.Tip="F1" Padding="4,2" FontSize="12"/>
          </StackPanel>

        </Grid>
      </Border>

      <!-- ── エディタ + プレビュー + チートシート ── -->
      <Grid Grid.Row="1" ColumnDefinitions="*,Auto">

        <!-- チートシートパネル（右端） -->
        <views:CheatSheetPanel Grid.Column="1"
                               DataContext="{Binding CheatSheet}"
                               IsVisible="{Binding IsVisible}"/>

        <!-- エディタ + プレビュー -->
        <Grid Grid.Column="0" ColumnDefinitions="*,Auto,*">

          <!-- Editor with Line Numbers -->
          <Border Grid.Column="0" Background="#1E1E1E">
            <Grid ColumnDefinitions="Auto,*">
              <Border Grid.Column="0" Background="#252526" Padding="8,4,8,4"
                      BorderBrush="#3E3E42" BorderThickness="0,0,1,0">
                <TextBlock x:Name="LineNumberBlock"
                           FontFamily="BIZ UDGothic, MS Gothic, Consolas, monospace"
                           FontSize="14" Foreground="#858585"
                           TextAlignment="Right" MinWidth="30" Text="1"/>
              </Border>
              <TextBox x:Name="EditorTextBox" Grid.Column="1"
                       Text="{Binding ActiveCardBody, Mode=TwoWay}"
                       AcceptsReturn="True" AcceptsTab="True"
                       TextWrapping="NoWrap"
                       FontFamily="BIZ UDGothic, MS Gothic, Consolas, monospace"
                       FontSize="14"
                       Background="#1E1E1E" Foreground="#DCDCDC"
                       CaretBrush="#AEAFAD" SelectionBrush="#264F78"
                       BorderThickness="0" Padding="4"/>
            </Grid>
          </Border>

          <!-- Splitter -->
          <GridSplitter Grid.Column="1" Width="4"
                        Background="Gray" Opacity="0.3"
                        IsVisible="{Binding IsPreviewVisible}"/>

          <!-- Preview（コードビハインドで WebView2 を配置） -->
          <Border Grid.Column="2"
                  IsVisible="{Binding IsPreviewVisible}"
                  BorderBrush="Gray" BorderThickness="1,0,0,0">
            <Grid x:Name="PreviewContainer"/>
          </Border>

        </Grid>
      </Grid>

      <!-- ── マイグレーション提案バー ── -->
      <Border Grid.Row="2"
              IsVisible="{Binding IsMigrationProposalVisible}"
              Background="#1B3A4B" BorderBrush="#2980B9" BorderThickness="0,1,0,0"
              Padding="12,8">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
          <TextBlock Grid.Column="0" Text="💡" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
          <TextBlock Grid.Column="1" Text="{Binding MigrationProposalText}"
                     Foreground="#E0E0E0" FontSize="13" VerticalAlignment="Center"
                     TextWrapping="Wrap"/>
          <Button Grid.Column="2" Content="本にする →"
                  Command="{Binding AcceptMigrationCommand}"
                  Foreground="White" Background="#2980B9"
                  Padding="12,4" Margin="8,0" FontSize="12" FontWeight="SemiBold"/>
          <Button Grid.Column="3" Content="今後表示しない"
                  Command="{Binding SuppressMigrationProposals_CommandCommand}"
                  Foreground="#999" Background="Transparent" BorderThickness="0"
                  Padding="8,4" FontSize="11"/>
          <Button Grid.Column="4" Content="✕"
                  Command="{Binding DismissMigrationProposalCommand}"
                  Foreground="#999" Background="Transparent" BorderThickness="0"
                  Padding="4,2" FontSize="12"/>
        </Grid>
      </Border>

      <!-- ── ステータスバー ── -->
      <Border Grid.Row="3" Background="#2D2D30" Padding="8,4">
        <StackPanel Orientation="Horizontal" Spacing="16">
          <TextBlock Text="{Binding StatsText}" Foreground="#DCDCDC"/>
          <TextBlock Text="{Binding MilestoneMessage}"
                     IsVisible="{Binding MilestoneMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                     Foreground="#6A9955" FontWeight="SemiBold"/>
        </StackPanel>
      </Border>

    </Grid>

  </Grid>

  <UserControl.Styles>

    <!-- ── カードボタン ── -->
    <Style Selector="Button.story-card">
      <Setter Property="Width"               Value="200"/>
      <Setter Property="Height"              Value="180"/>
      <Setter Property="Margin"              Value="0,0,8,8"/>
      <Setter Property="Padding"             Value="14"/>
      <Setter Property="Background"          Value="#2D2D30"/>
      <Setter Property="BorderBrush"         Value="#3E3E42"/>
      <Setter Property="BorderThickness"     Value="1"/>
      <Setter Property="CornerRadius"        Value="8"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="VerticalContentAlignment"   Value="Stretch"/>
      <Setter Property="Cursor"              Value="Hand"/>
    </Style>
    <Style Selector="Button.story-card /template/ ContentPresenter">
      <Setter Property="Background"      Value="#2D2D30"/>
      <Setter Property="BorderBrush"     Value="#3E3E42"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius"    Value="8"/>
    </Style>
    <Style Selector="Button.story-card:pointerover /template/ ContentPresenter">
      <Setter Property="Background"  Value="#333337"/>
      <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}"/>
    </Style>

  </UserControl.Styles>

</UserControl>
