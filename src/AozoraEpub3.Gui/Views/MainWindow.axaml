<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AozoraEpub3.Gui.ViewModels"
        x:Class="AozoraEpub3.Gui.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{DynamicResource Str_App_Title}"
        Width="1100" Height="720"
        MinWidth="800" MinHeight="560"
        WindowStartupLocation="CenterScreen">

  <!--
    ══════════════════════════════════════════════════════
    Shell レイアウト
    Row 0: ヘッダーバー（タイトル + 言語トグル）
    Row 1: SplitView（サイドバー + メインコンテンツ）
    ══════════════════════════════════════════════════════
  -->
  <Grid RowDefinitions="Auto,*">

    <!-- ══════ Row 0: ヘッダー ══════ -->
    <Border Grid.Row="0"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,0,0,1"
            Padding="16,0">
      <Grid ColumnDefinitions="*,Auto" Height="48">

        <!-- アプリタイトル -->
        <TextBlock Grid.Column="0"
                   Text="{DynamicResource Str_App_Title}"
                   FontSize="16" FontWeight="SemiBold"
                   VerticalAlignment="Center" />

        <!-- 言語切り替えトグル -->
        <StackPanel Grid.Column="1" Orientation="Horizontal"
                    Spacing="4" VerticalAlignment="Center">
          <Button Content="{DynamicResource Str_Lang_Ja}"
                  Command="{Binding SetLanguageCommand}"
                  CommandParameter="ja"
                  Classes.accent="{Binding IsJapanese}"
                  Padding="10,4" />
          <Button Content="{DynamicResource Str_Lang_En}"
                  Command="{Binding SetLanguageCommand}"
                  CommandParameter="en"
                  Classes.accent="{Binding !IsJapanese}"
                  Padding="10,4" />
        </StackPanel>

      </Grid>
    </Border>

    <!-- ══════ Row 1: SplitView（サイドバー + コンテンツ）══════ -->
    <!--
      DisplayMode="CompactInline" : サイドバーが常に表示（compact幅で常駐）
      PaneWidth : アイコン + テキストのラベル幅
    -->
    <SplitView Grid.Row="1"
               IsPaneOpen="True"
               DisplayMode="CompactInline"
               PanePlacement="Left"
               PaneBackground="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
               OpenPaneLength="180"
               CompactPaneLength="0">

      <!-- ── サイドバー ── -->
      <SplitView.Pane>
        <StackPanel Margin="0,12,0,0">

          <!-- ローカル変換 -->
          <Button Content="{DynamicResource Str_Nav_LocalConvert}"
                  Command="{Binding NavigateToCommand}"
                  CommandParameter="local"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Left"
                  Padding="16,12"
                  Classes="nav-item" />

          <!-- Web 変換 -->
          <Button Content="{DynamicResource Str_Nav_WebConvert}"
                  Command="{Binding NavigateToCommand}"
                  CommandParameter="web"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Left"
                  Padding="16,12"
                  Classes="nav-item" />

          <!-- 設定 -->
          <Button Content="{DynamicResource Str_Nav_Settings}"
                  Command="{Binding NavigateToCommand}"
                  CommandParameter="settings"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Left"
                  Padding="16,12"
                  Classes="nav-item" />

        </StackPanel>
      </SplitView.Pane>

      <!-- ── メインコンテンツ（SPA ContentControl）── -->
      <SplitView.Content>
        <!--
          CurrentPage が LocalConvertViewModel / WebConvertViewModel / SettingsPageViewModel
          に切り替わると、App.axaml の DataTemplates が対応する View を自動選択する。
        -->
        <ContentControl Content="{Binding CurrentPage}"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch" />
      </SplitView.Content>

    </SplitView>
  </Grid>

  <!-- ══════ スタイル定義 ══════ -->
  <Window.Styles>
    <!-- ナビゲーションボタン共通スタイル -->
    <Style Selector="Button.nav-item">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="FontSize" Value="14" />
    </Style>
    <Style Selector="Button.nav-item:pointerover /template/ ContentPresenter">
      <Setter Property="Background"
              Value="{DynamicResource SystemControlHighlightListLowBrush}" />
    </Style>
    <!-- accent クラス: 選択中の言語ボタン強調 -->
    <Style Selector="Button.accent">
      <Setter Property="Background"
              Value="{DynamicResource SystemAccentColor}" />
    </Style>
  </Window.Styles>

</Window>
