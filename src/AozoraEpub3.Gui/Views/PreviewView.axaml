<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AozoraEpub3.Gui.ViewModels"
             xmlns:ctrl="using:AozoraEpub3.Gui.Controls"
             xmlns:svc="using:AozoraEpub3.Gui.Services"
             x:Class="AozoraEpub3.Gui.Views.PreviewView"
             x:DataType="vm:PreviewViewModel">

  <!--
    ══════════════════════════════════════════════════════════════════════════
    EPUB プレビュー画面
    ─────────────────────────────────────────────────────────────────────────
    構成:
      Row 0: タイトルバー
      Row 1: メインコンテンツ（左: 目次パネル | GridSplitter | 右: WebView2）
      Row 2: ボトムツールバー（Prev / ページ表示 / Next / Open EPUB）
    ──────────────────────────────────────────────────────────────────────────
  -->
  <Grid RowDefinitions="Auto,*,Auto">

    <!-- ════════════════════════════════════════════════
         Row 0: タイトルバー
         ════════════════════════════════════════════════ -->
    <Border Grid.Row="0"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,0,0,1"
            Padding="12,8">
      <Grid ColumnDefinitions="Auto,*">
        <TextBlock Grid.Column="0"
                   Text="{DynamicResource Str_Preview_Title}"
                   FontSize="15"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center" />
        <TextBlock Grid.Column="1"
                   Text="{Binding WindowTitle}"
                   FontSize="13"
                   Opacity="0.7"
                   Margin="16,0,0,0"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" />
      </Grid>
    </Border>

    <!-- ════════════════════════════════════════════════
         Row 1: メインコンテンツエリア
         ════════════════════════════════════════════════ -->

    <!-- EPUB 未読み込み時のウェルカムメッセージ -->
    <StackPanel Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="16"
                IsVisible="{Binding !IsEpubLoaded}">

      <TextBlock Text="📖"
                 FontSize="64"
                 HorizontalAlignment="Center"
                 IsHitTestVisible="False" />

      <TextBlock Text="{DynamicResource Str_Preview_NoEpub}"
                 FontSize="14"
                 TextAlignment="Center"
                 HorizontalAlignment="Center"
                 Opacity="0.6"
                 MaxWidth="400"
                 TextWrapping="Wrap"
                 IsHitTestVisible="False" />

      <Button x:Name="WelcomeOpenButton"
              Content="{DynamicResource Str_Preview_OpenEpub}"
              HorizontalAlignment="Center"
              Padding="20,10"
              FontSize="14"
              Classes="accent" />
    </StackPanel>

    <!-- EPUB 読み込み済みのコンテンツ -->
    <Grid Grid.Row="1"
          RowDefinitions="*,Auto"
          IsVisible="{Binding IsEpubLoaded}">

    <Grid Grid.Row="0"
          ColumnDefinitions="Auto,Auto,Auto,*">

      <!-- ────── 目次トグルボタン（常に表示）────── -->
      <ToggleButton Grid.Column="0"
                    IsChecked="{Binding IsTocOpen}"
                    Width="24"
                    VerticalAlignment="Stretch"
                    Padding="2"
                    FontSize="10"
                    Background="Transparent"
                    BorderThickness="0">
        <Panel>
          <TextBlock Text="▶" IsVisible="{Binding !IsTocOpen}" HorizontalAlignment="Center" />
          <TextBlock Text="◀" IsVisible="{Binding IsTocOpen}" HorizontalAlignment="Center" />
        </Panel>
      </ToggleButton>

      <!-- ────── 左パネル: 目次 ────── -->
      <Border Grid.Column="1"
              x:Name="TocPanel"
              Width="220"
              IsVisible="{Binding IsTocOpen}"
              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
              BorderThickness="0,0,1,0">
        <Grid RowDefinitions="Auto,*">

          <!-- 目次ヘッダー -->
          <TextBlock Grid.Row="0"
                     Text="{DynamicResource Str_Preview_Toc}"
                     FontSize="12"
                     FontWeight="SemiBold"
                     Opacity="0.7"
                     Margin="8,6" />

          <!-- 目次リスト -->
          <ListBox Grid.Row="1"
                   x:Name="TocListBox"
                   ItemsSource="{Binding TocItems}"
                   SelectedItem="{Binding SelectedTocItem}"
                   BorderThickness="0"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="{x:Type svc:TocEntry}">
                <TextBlock Text="{Binding Label}"
                           TextTrimming="CharacterEllipsis"
                           Padding="4,3"
                           FontSize="12" />
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <!-- GridSplitter -->
      <GridSplitter Grid.Column="2"
                    Width="4"
                    Background="Transparent"
                    ResizeDirection="Columns"
                    ResizeBehavior="PreviousAndNext" />

      <!-- ────── 右: WebView2 コンテナ（コードビハインドで動的追加）────── -->
      <Border Grid.Column="3"
              x:Name="WebViewContainer"
              Background="{DynamicResource SystemControlBackgroundAltHighBrush}" />

    </Grid>

    <!-- ════════════════════════════════════════════════
         Row 1 (inner): CSS エディタパネル（トグル表示）
         ════════════════════════════════════════════════ -->
    <Border Grid.Row="1"
            IsVisible="{Binding CssEditor.IsVisible}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,1,0,0"
            MaxHeight="320">
      <Grid RowDefinitions="Auto,*,Auto">

        <!-- CSS エディタヘッダー -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto"
              Margin="8,4">
          <TextBlock Grid.Column="0"
                     Text="{DynamicResource Str_CssEditor_Title}"
                     FontSize="13" FontWeight="SemiBold"
                     VerticalAlignment="Center" />
          <TextBlock Grid.Column="1"
                     Text="{Binding CssEditor.StatusMessage}"
                     FontSize="11" Opacity="0.6"
                     VerticalAlignment="Center" Margin="12,0" />
          <ToggleButton Grid.Column="2"
                        IsChecked="{Binding CssEditor.IsAdvancedMode}"
                        Content="{DynamicResource Str_CssEditor_Advanced}"
                        Padding="8,2" FontSize="11" />
          <Button Grid.Column="3"
                  Command="{Binding CssEditor.OverwriteSaveCommand}"
                  Content="{DynamicResource Str_CssEditor_Overwrite}"
                  Padding="8,2" FontSize="11" Margin="4,0" />
          <Button Grid.Column="4"
                  Command="{Binding CssEditor.SaveAsCommand}"
                  Content="{DynamicResource Str_CssEditor_SaveAs}"
                  Padding="8,2" FontSize="11" Margin="4,0" />
          <Button Grid.Column="5"
                  Command="{Binding CssEditor.ResetCommand}"
                  Content="{DynamicResource Str_CssEditor_Reset}"
                  Padding="8,2" FontSize="11" />
        </Grid>

        <!-- 初心者モード: フォーム -->
        <ScrollViewer Grid.Row="1"
                      IsVisible="{Binding !CssEditor.IsAdvancedMode}"
                      Padding="8,0">
          <StackPanel Spacing="6">

            <!-- 書字方向 -->
            <StackPanel Orientation="Horizontal" Spacing="12">
              <RadioButton Content="{DynamicResource Str_Setting_Vertical}"
                           IsChecked="{Binding CssEditor.IsVertical}" />
              <RadioButton Content="{DynamicResource Str_Setting_Horizontal}"
                           IsChecked="{Binding !CssEditor.IsVertical}" />
            </StackPanel>

            <!-- フォントサイズ / 行送り -->
            <Grid ColumnDefinitions="Auto,100,24,Auto,100" Margin="0,4">
              <TextBlock Grid.Column="0"
                         Text="{DynamicResource Str_CssEditor_FontSize}"
                         VerticalAlignment="Center" FontSize="12" Margin="0,0,8,0" />
              <NumericUpDown Grid.Column="1"
                             Value="{Binding CssEditor.FontSize}"
                             Minimum="50" Maximum="300" Increment="5"
                             FormatString="0'%'"
                             FontSize="12" />
              <Panel Grid.Column="2" />
              <TextBlock Grid.Column="3"
                         Text="{DynamicResource Str_CssEditor_LineHeight}"
                         VerticalAlignment="Center" FontSize="12" Margin="0,0,8,0" />
              <NumericUpDown Grid.Column="4"
                             Value="{Binding CssEditor.LineHeight}"
                             Minimum="1.0" Maximum="3.0" Increment="0.1"
                             FormatString="0.0"
                             FontSize="12" />
            </Grid>

            <!-- ページマージン -->
            <TextBlock Text="{DynamicResource Str_CssEditor_PageMargin}"
                       FontSize="12" FontWeight="SemiBold" Margin="0,4,0,0" />
            <Grid ColumnDefinitions="Auto,80,8,Auto,80,8,Auto,80,8,Auto,80">
              <TextBlock Grid.Column="0" Text="Top" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
              <TextBox Grid.Column="1" Text="{Binding CssEditor.PageMarginTop}" FontSize="11" />
              <TextBlock Grid.Column="3" Text="Right" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
              <TextBox Grid.Column="4" Text="{Binding CssEditor.PageMarginRight}" FontSize="11" />
              <TextBlock Grid.Column="6" Text="Bottom" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
              <TextBox Grid.Column="7" Text="{Binding CssEditor.PageMarginBottom}" FontSize="11" />
              <TextBlock Grid.Column="9" Text="Left" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
              <TextBox Grid.Column="10" Text="{Binding CssEditor.PageMarginLeft}" FontSize="11" />
            </Grid>

            <!-- Body マージン -->
            <TextBlock Text="{DynamicResource Str_CssEditor_BodyMargin}"
                       FontSize="12" FontWeight="SemiBold" Margin="0,4,0,0" />
            <Grid ColumnDefinitions="Auto,80,8,Auto,80,8,Auto,80,8,Auto,80">
              <TextBlock Grid.Column="0" Text="Top" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
              <TextBox Grid.Column="1" Text="{Binding CssEditor.BodyMarginTop}" FontSize="11" />
              <TextBlock Grid.Column="3" Text="Right" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
              <TextBox Grid.Column="4" Text="{Binding CssEditor.BodyMarginRight}" FontSize="11" />
              <TextBlock Grid.Column="6" Text="Bottom" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
              <TextBox Grid.Column="7" Text="{Binding CssEditor.BodyMarginBottom}" FontSize="11" />
              <TextBlock Grid.Column="9" Text="Left" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
              <TextBox Grid.Column="10" Text="{Binding CssEditor.BodyMarginLeft}" FontSize="11" />
            </Grid>

            <!-- Bold/Gothic 設定 -->
            <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4">
              <CheckBox Content="{DynamicResource Str_CssEditor_BoldGothic}"
                        IsChecked="{Binding CssEditor.BoldUseGothic}" FontSize="12" />
              <CheckBox Content="{DynamicResource Str_CssEditor_GothicBold}"
                        IsChecked="{Binding CssEditor.GothicUseBold}" FontSize="12" />
            </StackPanel>

          </StackPanel>
        </ScrollViewer>

        <!-- 上級者モード: テキストエディタ -->
        <TextBox Grid.Row="1"
                 IsVisible="{Binding CssEditor.IsAdvancedMode}"
                 Text="{Binding CssEditor.CssText}"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 FontFamily="Consolas, Courier New, monospace"
                 FontSize="12"
                 MinHeight="180"
                 Margin="8,0" />

      </Grid>
    </Border>

    </Grid>

    <!-- ════════════════════════════════════════════════
         Row 2: ボトムツールバー
         ════════════════════════════════════════════════ -->
    <Border Grid.Row="2"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,1,0,0"
            Padding="8,6">
      <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto">

        <!-- Previous ボタン -->
        <Button Grid.Column="0"
                Content="{DynamicResource Str_Preview_Prev}"
                Command="{Binding GoPrevCommand}"
                Padding="10,4"
                FontSize="14" />

        <!-- ページ表示 -->
        <TextBlock Grid.Column="1"
                   Text="{Binding CurrentPageDisplay}"
                   FontSize="13"
                   VerticalAlignment="Center"
                   Margin="12,0"
                   MinWidth="60"
                   TextAlignment="Center" />

        <!-- Next ボタン -->
        <Button Grid.Column="2"
                Content="{DynamicResource Str_Preview_Next}"
                Command="{Binding GoNextCommand}"
                Padding="10,4"
                FontSize="14" />

        <!-- ステータスメッセージ + 層1→層2 導線 -->
        <StackPanel Grid.Column="3"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="16,0">
          <TextBlock Text="{Binding StatusMessage}"
                     FontSize="12"
                     Opacity="0.6"
                     TextTrimming="CharacterEllipsis" />
          <Button Content="自分でも書いてみる →"
                  Command="{Binding NavigateToCardsCommand}"
                  IsVisible="{Binding IsEpubLoaded}"
                  FontSize="11" Opacity="0.7"
                  Background="Transparent" BorderThickness="0"
                  Foreground="{DynamicResource SystemAccentColor}"
                  Padding="12,2" Margin="16,0,0,0"
                  Cursor="Hand"/>
        </StackPanel>

        <!-- フォント選択 + Open EPUB -->
        <StackPanel Grid.Column="4"
                    Orientation="Horizontal"
                    Spacing="8">
          <ComboBox ItemsSource="{Binding FontChoices}"
                    SelectedItem="{Binding SelectedFont}"
                    MinWidth="140"
                    FontSize="12"
                    VerticalAlignment="Center" />
          <ToggleButton IsChecked="{Binding CssEditor.IsVisible}"
                       Content="{DynamicResource Str_CssEditor_Toggle}"
                       Padding="8,4"
                       FontSize="12" />
          <Button x:Name="ValidateButton"
                  Content="{DynamicResource Str_Validate_PreviewButton}"
                  Padding="8,4"
                  FontSize="12" />
          <Button x:Name="ToolbarOpenButton"
                  Content="{DynamicResource Str_Preview_OpenEpub}"
                  Padding="12,4" />
          <Button x:Name="MaximizeButton"
                  Content="⛶"
                  ToolTip.Tip="最大化 / 元に戻す"
                  Padding="8,4"
                  FontSize="16" />
        </StackPanel>

      </Grid>
    </Border>

  </Grid>

</UserControl>
