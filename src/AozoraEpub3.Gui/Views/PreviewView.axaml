<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AozoraEpub3.Gui.ViewModels"
             xmlns:ctrl="using:AozoraEpub3.Gui.Controls"
             xmlns:svc="using:AozoraEpub3.Gui.Services"
             x:Class="AozoraEpub3.Gui.Views.PreviewView"
             x:DataType="vm:PreviewViewModel">

  <!--
    ══════════════════════════════════════════════════════════════════════════
    EPUB プレビュー画面
    ─────────────────────────────────────────────────────────────────────────
    構成:
      Row 0: タイトルバー
      Row 1: メインコンテンツ（左: 目次パネル | GridSplitter | 右: WebView2）
      Row 2: ボトムツールバー（Prev / ページ表示 / Next / Open EPUB）
    ──────────────────────────────────────────────────────────────────────────
  -->
  <Grid RowDefinitions="Auto,*,Auto">

    <!-- ════════════════════════════════════════════════
         Row 0: タイトルバー
         ════════════════════════════════════════════════ -->
    <Border Grid.Row="0"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,0,0,1"
            Padding="12,8">
      <Grid ColumnDefinitions="Auto,*">
        <TextBlock Grid.Column="0"
                   Text="{DynamicResource Str_Preview_Title}"
                   FontSize="15"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center" />
        <TextBlock Grid.Column="1"
                   Text="{Binding WindowTitle}"
                   FontSize="13"
                   Opacity="0.7"
                   Margin="16,0,0,0"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" />
      </Grid>
    </Border>

    <!-- ════════════════════════════════════════════════
         Row 1: メインコンテンツエリア
         ════════════════════════════════════════════════ -->

    <!-- EPUB 未読み込み時のウェルカムメッセージ -->
    <StackPanel Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="16"
                IsVisible="{Binding !IsEpubLoaded}">

      <TextBlock Text="📖"
                 FontSize="64"
                 HorizontalAlignment="Center"
                 IsHitTestVisible="False" />

      <TextBlock Text="{DynamicResource Str_Preview_NoEpub}"
                 FontSize="14"
                 TextAlignment="Center"
                 HorizontalAlignment="Center"
                 Opacity="0.6"
                 MaxWidth="400"
                 TextWrapping="Wrap"
                 IsHitTestVisible="False" />

      <Button x:Name="WelcomeOpenButton"
              Content="{DynamicResource Str_Preview_OpenEpub}"
              HorizontalAlignment="Center"
              Padding="20,10"
              FontSize="14"
              Classes="accent" />
    </StackPanel>

    <!-- EPUB 読み込み済みのコンテンツ -->
    <Grid Grid.Row="1"
          ColumnDefinitions="Auto,Auto,Auto,*"
          IsVisible="{Binding IsEpubLoaded}">

      <!-- ────── 目次トグルボタン（常に表示）────── -->
      <ToggleButton Grid.Column="0"
                    IsChecked="{Binding IsTocOpen}"
                    Width="24"
                    VerticalAlignment="Stretch"
                    Padding="2"
                    FontSize="10"
                    Background="Transparent"
                    BorderThickness="0">
        <Panel>
          <TextBlock Text="▶" IsVisible="{Binding !IsTocOpen}" HorizontalAlignment="Center" />
          <TextBlock Text="◀" IsVisible="{Binding IsTocOpen}" HorizontalAlignment="Center" />
        </Panel>
      </ToggleButton>

      <!-- ────── 左パネル: 目次 ────── -->
      <Border Grid.Column="1"
              x:Name="TocPanel"
              Width="220"
              IsVisible="{Binding IsTocOpen}"
              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
              BorderThickness="0,0,1,0">
        <Grid RowDefinitions="Auto,*">

          <!-- 目次ヘッダー -->
          <TextBlock Grid.Row="0"
                     Text="{DynamicResource Str_Preview_Toc}"
                     FontSize="12"
                     FontWeight="SemiBold"
                     Opacity="0.7"
                     Margin="8,6" />

          <!-- 目次リスト -->
          <ListBox Grid.Row="1"
                   x:Name="TocListBox"
                   ItemsSource="{Binding TocItems}"
                   SelectedItem="{Binding SelectedTocItem}"
                   BorderThickness="0"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="{x:Type svc:TocEntry}">
                <TextBlock Text="{Binding Label}"
                           TextTrimming="CharacterEllipsis"
                           Padding="4,3"
                           FontSize="12" />
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <!-- GridSplitter -->
      <GridSplitter Grid.Column="2"
                    Width="4"
                    Background="Transparent"
                    ResizeDirection="Columns"
                    ResizeBehavior="PreviousAndNext" />

      <!-- ────── 右: WebView2 コンテナ（コードビハインドで動的追加）────── -->
      <Border Grid.Column="3"
              x:Name="WebViewContainer"
              Background="{DynamicResource SystemControlBackgroundAltHighBrush}" />

    </Grid>

    <!-- ════════════════════════════════════════════════
         Row 2: ボトムツールバー
         ════════════════════════════════════════════════ -->
    <Border Grid.Row="2"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,1,0,0"
            Padding="8,6">
      <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto">

        <!-- Previous ボタン -->
        <Button Grid.Column="0"
                Content="{DynamicResource Str_Preview_Prev}"
                Command="{Binding GoPrevCommand}"
                Padding="10,4"
                FontSize="14" />

        <!-- ページ表示 -->
        <TextBlock Grid.Column="1"
                   Text="{Binding CurrentPageDisplay}"
                   FontSize="13"
                   VerticalAlignment="Center"
                   Margin="12,0"
                   MinWidth="60"
                   TextAlignment="Center" />

        <!-- Next ボタン -->
        <Button Grid.Column="2"
                Content="{DynamicResource Str_Preview_Next}"
                Command="{Binding GoNextCommand}"
                Padding="10,4"
                FontSize="14" />

        <!-- ステータスメッセージ -->
        <TextBlock Grid.Column="3"
                   Text="{Binding StatusMessage}"
                   FontSize="12"
                   Opacity="0.6"
                   VerticalAlignment="Center"
                   Margin="16,0"
                   TextTrimming="CharacterEllipsis" />

        <!-- フォント選択 + Open EPUB -->
        <StackPanel Grid.Column="4"
                    Orientation="Horizontal"
                    Spacing="8">
          <ComboBox ItemsSource="{Binding FontChoices}"
                    SelectedItem="{Binding SelectedFont}"
                    MinWidth="140"
                    FontSize="12"
                    VerticalAlignment="Center" />
          <Button x:Name="ToolbarOpenButton"
                  Content="{DynamicResource Str_Preview_OpenEpub}"
                  Padding="12,4" />
          <Button x:Name="MaximizeButton"
                  Content="⛶"
                  ToolTip.Tip="最大化 / 元に戻す"
                  Padding="8,4"
                  FontSize="16" />
        </StackPanel>

      </Grid>
    </Border>

  </Grid>

</UserControl>
