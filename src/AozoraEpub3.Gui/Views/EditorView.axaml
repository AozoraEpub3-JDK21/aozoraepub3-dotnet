<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AozoraEpub3.Gui.ViewModels"
             xmlns:views="using:AozoraEpub3.Gui.Views"
             x:Class="AozoraEpub3.Gui.Views.EditorView"
             x:DataType="vm:EditorViewModel">

  <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">

    <!-- ToolBar -->
    <Border Grid.Row="0"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,0,0,1"
            Padding="4,4">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">

        <!-- ≡ ファイル・ツールメニュー -->
        <Button Grid.Column="0"
                Content="≡" Padding="8,4" FontSize="14"
                ToolTip.Tip="ファイル操作・ツール">
          <Button.Flyout>
            <MenuFlyout>
              <MenuItem Header="新規 (Ctrl+N)"  Command="{Binding NewFileCommand}" />
              <MenuItem Header="開く (Ctrl+O)"  Command="{Binding OpenFileCommand}" />
              <MenuItem Header="保存 (Ctrl+S)"  Command="{Binding SaveFileCommand}" />
              <Separator/>
              <MenuItem Header="校正"           Command="{Binding ProofreadCommand}" />
              <MenuItem Header="EPUB変換"       Command="{Binding ConvertToEpubCommand}" />
            </MenuFlyout>
          </Button.Flyout>
        </Button>

        <Border Grid.Column="1" Width="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}"
                Margin="4,4" VerticalAlignment="Stretch"/>

        <!-- モード -->
        <ComboBox Grid.Column="2"
                  ItemsSource="{Binding ModeNames}"
                  SelectedIndex="{Binding SelectedModeIndex}"
                  Width="75" FontSize="12" VerticalAlignment="Center"
                  Margin="4,0" HorizontalAlignment="Left"/>

        <!-- 記法・書式ボタン -->
        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="2">
          <Border Width="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}"
                  Margin="2,4" VerticalAlignment="Stretch"/>
          <Button Content="ルビ"   Command="{Binding InsertSnippetCommand}" CommandParameter="ruby"
                  ToolTip.Tip="Ctrl+R" Padding="4,2" FontSize="12"/>
          <Button Content="傍点"   Command="{Binding InsertSnippetCommand}" CommandParameter="emphasis"
                  ToolTip.Tip="Ctrl+E" Padding="4,2" FontSize="12"/>
          <Button Content="太字"   Command="{Binding InsertSnippetCommand}" CommandParameter="bold"
                  ToolTip.Tip="Ctrl+B" Padding="4,2" FontSize="12"/>
          <Button Content="見出し" Command="{Binding InsertSnippetCommand}" CommandParameter="heading"
                  ToolTip.Tip="Ctrl+H" Padding="4,2" FontSize="12"/>
          <Button Content="改頁"   Command="{Binding InsertSnippetCommand}" CommandParameter="pagebreak"
                  Padding="4,2" FontSize="12"/>
          <Border Width="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}"
                  Margin="2,4" VerticalAlignment="Stretch"/>
          <ToggleButton Content="縦書" IsChecked="{Binding IsVertical}" Padding="4,2" FontSize="12"/>
          <Button Content="自動修正" Command="{Binding FormatTextCommand}"
                  ToolTip.Tip="……・──など自動補正 (Ctrl+Shift+F)" Padding="4,2" FontSize="12"/>
        </StackPanel>

        <!-- アクションボタン -->
        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="2">
          <Border Width="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}"
                  Margin="2,4" VerticalAlignment="Stretch"/>
          <ToggleButton Content="縦書確認" IsChecked="{Binding IsPreviewVisible}"
                        ToolTip.Tip="F5" Padding="4,2" FontSize="12"/>
          <Border Width="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}"
                  Margin="2,4" VerticalAlignment="Stretch"/>
          <Button Content="EPUB変換" Command="{Binding ConvertToEpubCommand}"
                  Padding="4,2" FontSize="12" FontWeight="SemiBold"/>
          <Border Width="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}"
                  Margin="2,4" VerticalAlignment="Stretch"/>
          <ToggleButton Content="？" IsChecked="{Binding CheatSheet.IsVisible}"
                        ToolTip.Tip="F1" Padding="4,2" FontSize="12"/>
        </StackPanel>

      </Grid>
    </Border>

    <!-- 検索・置換パネル (Row 1) -->
    <Border Grid.Row="1"
            IsVisible="{Binding IsFindReplaceVisible}"
            Background="#252526" BorderBrush="#3E3E42" BorderThickness="0,0,0,1"
            Padding="8,6">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,*,Auto,Auto,Auto,Auto">
        <TextBlock Grid.Column="0" Text="検索：" Foreground="#DCDCDC" FontSize="12"
                   VerticalAlignment="Center" Margin="0,0,4,0"/>
        <TextBox Grid.Column="1" x:Name="FindTextBox"
                 Text="{Binding FindText, Mode=TwoWay}"
                 Watermark="検索文字列"
                 FontSize="12" Height="28" Padding="4,2" MinWidth="160"
                 Background="#1E1E1E" Foreground="#DCDCDC" CaretBrush="#AEAFAD"
                 BorderBrush="#3E3E42"/>
        <TextBlock Grid.Column="2" Text="{Binding FindResultInfo}"
                   Foreground="#6A9955" FontSize="11"
                   VerticalAlignment="Center" Margin="6,0" MinWidth="70"/>
        <Button Grid.Column="3" Content="↑" Command="{Binding FindPrevCommand}"
                ToolTip.Tip="前を検索 (Shift+Enter)" Padding="6,2" FontSize="12" Margin="2,0"/>
        <Button Grid.Column="4" Content="↓" Command="{Binding FindNextCommand}"
                ToolTip.Tip="次を検索 (Enter)" Padding="6,2" FontSize="12" Margin="2,0"/>
        <Border Grid.Column="5" Width="1" Background="#3E3E42" Margin="6,2" VerticalAlignment="Stretch"/>
        <TextBox Grid.Column="6" x:Name="ReplaceTextBox"
                 Text="{Binding ReplaceText, Mode=TwoWay}"
                 Watermark="置換文字列"
                 FontSize="12" Height="28" Padding="4,2" MinWidth="160"
                 Background="#1E1E1E" Foreground="#DCDCDC" CaretBrush="#AEAFAD"
                 BorderBrush="#3E3E42"/>
        <Button Grid.Column="7" Content="置換" Command="{Binding ReplaceCommand}"
                Padding="6,2" FontSize="12" Margin="4,0,2,0"/>
        <Button Grid.Column="8" Content="全置換" Command="{Binding ReplaceAllCommand}"
                Padding="6,2" FontSize="12" Margin="2,0"/>
        <Border Grid.Column="9" Width="1" Background="#3E3E42" Margin="6,2" VerticalAlignment="Stretch"/>
        <Button Grid.Column="10" Content="✕" Command="{Binding CloseFindReplaceCommand}"
                Foreground="#999" Background="Transparent" BorderThickness="0"
                Padding="4,2" FontSize="12"/>
      </Grid>
    </Border>

    <!-- Editor + Preview Split + CheatSheet -->
    <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
      <!-- チートシートパネル（右端） -->
      <views:CheatSheetPanel Grid.Column="1"
                             DataContext="{Binding CheatSheet}"
                             IsVisible="{Binding IsVisible}"/>
      <!-- エディタ + プレビュー -->
    <Grid Grid.Column="0" ColumnDefinitions="*,Auto,*">

      <!-- Editor with Line Numbers -->
      <Border Grid.Column="0" Background="#1E1E1E">
        <Grid ColumnDefinitions="Auto,*">
          <!-- Line Number Panel -->
          <Border Grid.Column="0" Background="#252526" Padding="8,4,8,4"
                  BorderBrush="#3E3E42" BorderThickness="0,0,1,0">
            <TextBlock x:Name="LineNumberBlock"
                       FontFamily="BIZ UDGothic, MS Gothic, Consolas, monospace"
                       FontSize="14"
                       Foreground="#858585"
                       TextAlignment="Right"
                       MinWidth="30"
                       Text="1"/>
          </Border>

          <!-- Main TextBox -->
          <TextBox x:Name="EditorTextBox" Grid.Column="1"
                   Text="{Binding EditorText, Mode=TwoWay}"
                   AcceptsReturn="True"
                   AcceptsTab="True"
                   TextWrapping="NoWrap"
                   FontFamily="BIZ UDGothic, MS Gothic, Consolas, monospace"
                   FontSize="14"
                   Background="#1E1E1E"
                   Foreground="#DCDCDC"
                   CaretBrush="#AEAFAD"
                   SelectionBrush="#264F78"
                   BorderThickness="0"
                   Padding="4"/>
        </Grid>
      </Border>

      <!-- Splitter -->
      <GridSplitter Grid.Column="1" Width="4"
                    Background="Gray" Opacity="0.3"
                    IsVisible="{Binding IsPreviewVisible}"/>

      <!-- Preview (WebView2Host wired in code-behind) -->
      <Border Grid.Column="2"
              IsVisible="{Binding IsPreviewVisible}"
              BorderBrush="Gray" BorderThickness="1,0,0,0">
        <Grid x:Name="PreviewContainer"/>
      </Border>

    </Grid>
    </Grid>

    <!-- 校正結果パネル -->
    <Border Grid.Row="3"
            IsVisible="{Binding IsProofreadingPanelVisible}"
            Background="#1B2838" BorderBrush="#3E3E42" BorderThickness="0,1,0,0"
            MaxHeight="150">
      <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Background="#252526">
          <TextBlock Grid.Column="0" Text="校正結果" Foreground="#DCDCDC"
                     FontWeight="SemiBold" FontSize="12" Margin="8,4"/>
          <Button Grid.Column="1" Content="✕" Command="{Binding CloseProofreadingCommand}"
                  Foreground="#999" Background="Transparent" BorderThickness="0"
                  Padding="4,2" FontSize="12"/>
        </Grid>
        <ListBox Grid.Row="1" ItemsSource="{Binding ProofreadingResults}"
                 Background="Transparent" BorderThickness="0">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal" Spacing="8" Margin="4,2">
                <TextBlock Text="{Binding Rule}" Foreground="#569CD6" FontSize="11" MinWidth="25"/>
                <TextBlock Text="{Binding Line, StringFormat='L{0}'}" Foreground="#6A9955" FontSize="11" MinWidth="30"/>
                <TextBlock Text="{Binding Message}" Foreground="#DCDCDC" FontSize="11" TextWrapping="NoWrap"/>
                <TextBlock Text="{Binding Suggestion, StringFormat='→ {0}'}" Foreground="#CE9178" FontSize="11"
                           IsVisible="{Binding Suggestion, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>

    <!-- StatusBar -->
    <Border Grid.Row="4" Background="#2D2D30" Padding="8,4">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Orientation="Horizontal" Spacing="16">
          <TextBlock Text="{Binding WindowTitle}" FontWeight="SemiBold" Foreground="#DCDCDC"/>
          <TextBlock Foreground="#DCDCDC">
            <Run Text="{Binding CharacterCount}"/><Run Text="字"/>
          </TextBlock>
          <TextBlock Foreground="#858585" FontSize="11">
            <Run Text="原稿用紙"/><Run Text="{Binding ManuscriptPageCount}"/><Run Text="枚"/>
          </TextBlock>
          <TextBlock Foreground="#DCDCDC">
            <Run Text="{Binding LineCount}"/><Run Text="行"/>
          </TextBlock>
        </StackPanel>
        <TextBlock Grid.Column="1"
                   Text="{Binding SelectionInfo}"
                   IsVisible="{Binding SelectionInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   Foreground="#569CD6" FontSize="11"
                   VerticalAlignment="Center"/>
      </Grid>
    </Border>

  </Grid>

</UserControl>
